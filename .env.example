PORT=4000
POLL_INTERVAL_MS=3000
ALERT_THRESHOLD_PERCENT=0.25
DISCORD_WEBHOOK_URL=

# Comma-separated symbols to track. Built-in adapters derive exchange pair ids from these.
TRACKED_MARKETS=BTC/USD,ETH/USD,SOL/USD

# Optional fee overrides as decimal rates.
EXCHANGE_FEES=binance:0.001,kraken:0.0026,coinbase:0.006

# Optional custom normalized quote APIs: name:url,name:url
# Endpoint response can be [{ "symbol": "BTC/USD", "bid": 65000, "ask": 65010 }]
# or { "quotes": [{ "symbol": "BTC/USD", "bid": 65000, "ask": 65010 }] }
CUSTOM_QUOTE_ENDPOINTS=
